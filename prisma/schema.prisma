generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  service   String
  message   String
  createdAt DateTime @default(now())
}